KRAKEND_ADDR=http://krakend:8082
KRAKEND_PORT=8082
KRAKEND_API_KEY=api-key
DISABLED_ENDPOINTS=sdsi,download
LOG_LEVEL=DEBUG
DEBUG_ENDPOINT=true
ECHO_ENDPOINT=true
SDAPPLY_CONFIG_BASE=sdapply-remote.json
KRAKEND_LICENSE_PATH=/etc/krakend/LICENSE_DEV
DEFAULT_TIMEOUT=10
SDSI_TIMEOUT=80
VAULT_HEADERS_TIMEOUT=60

S3_TIMEOUT=60
S3_REGION=us-east-1
FINDATA_S3_REGION=us-east-1

EPOUTA_IP_ADDRESS=10.0.0.3

DB_STRING_SDA_BP=""
DB_STRING_GUACAMOLE=host=krakend-db port=5432 user=postgres dbname=guacamoledb sslmode=disable
DB_PWD_GUACAMOLE=password
POSTGRES_PASSWORD=password
POSTGRES_USER=postgres

REDIS_URL=krakend-redis:6379
REDIS_PASSWORD=password2
REDIS_TTL=36000

CLAMAV_TIMEOUT=200

DB_DATASETS_FEGA=EGAD1000;test-resource;nonexistent-dataset
SDAPPLY_PROJECT=project_2002145
BIGPICTURE_PROJECT=project_2002145
FEGA_BUCKET=fega-test-bucket
BIGPICTURE_BUCKET=bp-test-bucket
